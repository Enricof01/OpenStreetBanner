generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Location {
  id        Int      @id @default(autoincrement())
  name      String?
  lat       Float
  lng       Float
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Message   String?
}
